#### Xray VPN server ####
# Xray official Docker image.
# This config follows the current Project X docs that use VLESS `users`.
# Re-check Xray release notes before changing this tag.
XRAY_IMAGE=ghcr.io/xtls/xray-core:26.5.9

# Container name shown in `docker ps` and OrbStack UI.
COMPOSE_PROJECT_NAME=vless-reality-vpn


#### ddns server ####
# Namecheap Dynamic DNS. Start with:
# docker compose --profile ddns up -d --build namecheap-ddns
#
# Feature flag. Leave false when you do not use Namecheap DDNS.
DDNS_ENABLED=false

# Use "@" for the bare domain, or only the subdomain label such as "vpn" for
# vpn.example.com.
NAMECHEAP_DDNS_HOST=
NAMECHEAP_DDNS_DOMAIN=

# Use the Dynamic DNS password from Namecheap Advanced DNS, not your account
# password. Keep real values only in .env.
NAMECHEAP_DDNS_PASSWORD=

# Optional. Leave empty to let Namecheap use the request source IP.
NAMECHEAP_DDNS_IP=

# Default: every 15 minutes.
NAMECHEAP_DDNS_CRON=*/15 * * * *
NAMECHEAP_DDNS_ENDPOINT=https://dynamicdns.park-your-domain.com/update
NAMECHEAP_DDNS_DRY_RUN=false
